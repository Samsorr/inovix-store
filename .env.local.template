# Medusa backend
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=

# Public site URL (used for canonical URLs, OG tags, sitemap)
NEXT_PUBLIC_SITE_URL=https://inovix.eu

# Resend (contact form, transactional email) — leave blank until domain is set up
RESEND_API_KEY=
CONTACT_EMAIL=

# Optional: postcode.tech API key for higher rate limits
POSTCODE_TECH_KEY=

# Sentry (error monitoring) — leave blank to disable Sentry entirely
# Get DSN from sentry.io → your project → Settings → Client Keys (DSN)
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
# SENTRY_ENVIRONMENT=production
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_TRACES_SAMPLE_RATE=0.1
# Source map upload (for readable prod stack traces) — get auth token at
# sentry.io/settings/auth-tokens with scopes: project:releases, org:read
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=
